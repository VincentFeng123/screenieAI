{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Screenie AI",
  "version": "0.1.0",
  "identifier": "com.screenieai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Screenie AI",
        "width": 1120,
        "height": 640,
        "minWidth": 960,
        "minHeight": 560,
        "visible": false,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active",
          "radius": 24
        }
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
